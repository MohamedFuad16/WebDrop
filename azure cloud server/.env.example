# WebDrop signaling server
NODE_ENV=production
HOST=127.0.0.1
PORT=8080
PUBLIC_ORIGIN=https://signal.webdrop.example.com
ALLOWED_ORIGINS=https://web-drop-lyart.vercel.app,https://webdrop.example.com,http://localhost:4178,http://127.0.0.1:4178,http://localhost:4180,http://127.0.0.1:4180
REQUIRE_TURN_AUTH=true
MAX_JSON_BYTES=65536
SESSION_TTL_MS=900000
HEARTBEAT_INTERVAL_MS=25000
PAIRING_TTL_MS=120000
ENABLE_PROXIMITY_ANALYSIS=true
QR_TOKEN_TTL_MS=120000

# Proximity-pairing capacity + acoustic cohort tuning (all optional; unset uses
# the safe defaults shown). The system supports MANY concurrent proximity
# sessions, each kept a SMALL acoustic cohort so per-session time slots stay
# reliable. Raising the global cap toward 10,000 is just config here, but real
# 10k needs the multi-node/shared-presence path in README (Redis + sticky WS).
#
# Global participant cap across ALL concurrent sessions. Joins beyond it are
# rejected cleanly (proximity:session:failed reason=capacity_reached).
MAX_TOTAL_PROXIMITY_PARTICIPANTS=100
# Per-session acoustic cohort cap. CLAMPED to the slot-floor ceiling derived from
# the ceremony window so a session can never schedule sub-floor acoustic slots.
# With a 3600 ms window and ~600 ms slot floor the ceiling is 6; raising this
# above the ceiling has no effect unless PROXIMITY_SESSION_DURATION_MS also grows.
MAX_PROXIMITY_SESSION_CLIENTS=6
# Ceremony intervals (ms). Tunable live; the cohort ceiling is recomputed from
# the duration and the ~600 ms acoustic slot floor.
PROXIMITY_SESSION_JOIN_WINDOW_MS=1800
PROXIMITY_SESSION_START_DELAY_MS=1200
PROXIMITY_SESSION_DURATION_MS=3600
PROXIMITY_SESSION_TTL_MS=15000
PROXIMITY_SESSION_MATCH_SLOP_MS=4000
# Shared ultrasonic band. Widening the end frequency (on devices whose mics
# sample high enough) lets concurrent cohorts split into different sub-bands.
ACOUSTIC_BAND_START_HZ=18600
ACOUSTIC_BAND_END_HZ=19400
ACOUSTIC_MIN_BANDWIDTH_HZ=420
# Cross-session acoustic de-confliction. Stagger spreads concurrent cohorts that
# fill at the same instant across N time phases (phase 0 = no offset). Set
# ACOUSTIC_SESSION_STAGGER_MS=0 to disable. Sub-band cap bounds how many distinct
# frequency lanes are used when the band is wide enough to fit them.
ACOUSTIC_SESSION_STAGGER_MS=600
ACOUSTIC_SESSION_STAGGER_PHASES=3
ACOUSTIC_MAX_CONCURRENT_SUBBANDS=4
# Operations diagnostics + metrics. The admin dashboard reads /api/diagnostics-public
# (and /api/metrics-summary) and BOTH now require the bearer token below. Enable the
# endpoint and set a strong, non-placeholder token (e.g. `openssl rand -base64 32`).
# Distribute the same value to the frontend via the gitignored js/config/local-admin-token.js.
ENABLE_METRICS_ENDPOINT=true
METRICS_API_TOKEN=replace-with-random-observability-token

# Cloudflare TURN Server
# Keep these only on the server/Azure VM instance. Never put the API token in frontend code.
CLOUDFLARE_TURN_KEY_ID=replace-with-cloudflare-turn-key-id
CLOUDFLARE_TURN_API_TOKEN=replace-with-cloudflare-turn-api-token
TURN_TTL_SECONDS=86400
TURN_CACHE_SECONDS=30
TURN_RELAY_LIMIT_BYTES=524288000

# Local development: keep true until real Cloudflare credentials are configured.
ALLOW_STUN_FALLBACK=true
