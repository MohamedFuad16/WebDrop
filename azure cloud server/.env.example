# WebDrop signaling server
NODE_ENV=production
HOST=127.0.0.1
PORT=8080
PUBLIC_ORIGIN=https://signal.webdrop.example.com
ALLOWED_ORIGINS=https://web-drop-lyart.vercel.app,https://webdrop.example.com,http://localhost:4178,http://127.0.0.1:4178,http://localhost:4180,http://127.0.0.1:4180
REQUIRE_TURN_AUTH=true
MAX_JSON_BYTES=65536
SESSION_TTL_MS=900000
HEARTBEAT_INTERVAL_MS=25000
PAIRING_TTL_MS=120000
ENABLE_PROXIMITY_ANALYSIS=false
QR_TOKEN_TTL_MS=120000
ENABLE_METRICS_ENDPOINT=false
METRICS_API_TOKEN=replace-with-random-observability-token

# Cloudflare TURN Server
# Keep these only on the server/Azure VM instance. Never put the API token in frontend code.
CLOUDFLARE_TURN_KEY_ID=replace-with-cloudflare-turn-key-id
CLOUDFLARE_TURN_API_TOKEN=replace-with-cloudflare-turn-api-token
TURN_TTL_SECONDS=86400
TURN_CACHE_SECONDS=30
TURN_RELAY_LIMIT_BYTES=524288000

# Local development: keep true until real Cloudflare credentials are configured.
ALLOW_STUN_FALLBACK=true
