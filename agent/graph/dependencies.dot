// WebDrop v2 — static ES-module dependency graph for js/ (+ workers/).
// Generated by reading the real `import ... from` statements (the `?v=1.0.90`
// cache-busting query strings defeat madge/dependency-cruiser auto-resolution,
// so edges were extracted deterministically by hand). Regenerate by re-reading
// import statements if modules change.
//
// Render: dot -Tsvg agent/graph/dependencies.dot -o dependencies.svg  (needs graphviz)
digraph webdrop_v2 {
  rankdir=LR;
  node [shape=box, style=rounded, fontname="Helvetica", fontsize=10];

  // ---- entry points ----
  "js/app.js"            [style="rounded,filled", fillcolor="#cde8ff"];
  "js/admin/readiness.js"[style="rounded,filled", fillcolor="#cde8ff"];

  // ---- app bootstrap ----
  "js/app.js" -> "js/core/state.js";
  "js/app.js" -> "js/core/controller.js";
  "js/app.js" -> "js/services/capabilities.js";
  "js/app.js" -> "js/services/mock-signaling.js";
  "js/app.js" -> "js/services/websocket-signaling.js";
  "js/app.js" -> "js/services/turn-config.js";
  "js/app.js" -> "js/services/proximity-engine.js";
  "js/app.js" -> "js/services/webrtc-transport.js";
  "js/app.js" -> "js/services/transfer-engine.js";
  "js/app.js" -> "js/storage/storage-client.js";
  "js/app.js" -> "js/ui/app-view.js";
  "js/app.js" -> "js/config/avatar-options.js";
  "js/app.js" -> "js/config/runtime-flags.js";

  // ---- core ----
  "js/core/controller.js" -> "js/utils/format.js";
  "js/core/controller.js" -> "js/utils/received-files.js";
  "js/core/controller.js" -> "js/services/proximity-engine.js";

  // ---- services ----
  "js/services/webrtc-transport.js" -> "js/utils/emitter.js";
  "js/services/webrtc-transport.js" -> "js/services/data-channel-transfer-protocol.js";
  "js/services/websocket-signaling.js" -> "js/utils/emitter.js";
  "js/services/mock-signaling.js" -> "js/utils/emitter.js";
  "js/services/mock-signaling.js" -> "js/config/avatar-options.js";
  "js/services/transfer-engine.js" -> "js/utils/emitter.js";
  "js/services/data-channel-transfer-protocol.js" -> "js/utils/emitter.js";
  "js/services/data-channel-transfer-protocol.js" -> "workers/incremental-sha256.js";
  "js/services/proximity-engine.js" -> "js/services/acoustic-proximity.js";
  "js/services/proximity-engine.js" -> "js/services/motion-proximity.js";
  "js/services/proximity-engine.js" -> "js/services/proximity-token.js";

  // ---- storage ----
  "js/storage/storage-client.js" -> "js/vendor/streamsaver-adapter.js";

  // ---- ui ----
  "js/ui/app-view.js" -> "js/utils/emitter.js";
  "js/ui/app-view.js" -> "js/utils/format.js";
  "js/ui/app-view.js" -> "js/config/avatar-options.js";
  "js/ui/app-view.js" -> "js/config/i18n.js";
  "js/ui/app-view.js" -> "js/utils/received-files.js";
  "js/ui/app-view.js" -> "js/ui/dynamic-island.js";
  "js/ui/dynamic-island.js" -> "js/vendor/qrcode-generator.mjs";
  "js/ui/dynamic-island.js" -> "js/utils/emitter.js";
  "js/ui/dynamic-island.js" -> "js/utils/format.js";
  "js/ui/dynamic-island.js" -> "js/config/avatar-options.js";
  "js/ui/dynamic-island.js" -> "js/ui/tile-wave.js";
  "js/ui/dynamic-island.js" -> "js/services/proximity-engine.js";

  // ---- admin dashboard (separate entry, loaded by admin/index.html) ----
  "js/admin/readiness.js" -> "js/admin/operations-i18n.js";
  "js/admin/readiness.js" -> "js/admin/diagnostics-api.js";
  "js/admin/readiness.js" -> "js/admin/shared.js";

  // ---- orphan / test-only (NOT imported by runtime modules) ----
  "js/ui/siri-wave.js" [style="rounded,filled", fillcolor="#ffe0b2"];
  // js/ui/siri-wave.js is dynamically imported only by tests/e2e/app-ui.spec.mjs
  // and precached by service-worker.js; no static runtime import edges.
}
